node_modules/
dist/
coverage/

# pnpm local content-addressable store (if ever set to a repo-local path
# via .npmrc `store-dir`). Default is `~/.local/share/pnpm/store` which
# lives outside the repo, but this entry keeps `pnpm store` output from
# accidentally tracked if the config is changed.
.pnpm-store/

# SvelteKit UI build output (regenerated by `npm run build:ui`)
ui/.svelte-kit/
ui/build/
.env
.env.local
.env.*.local
*.log
.DS_Store
.idea/
.vscode/
!.vscode/settings.json.example
.claude/

# Operator convenience scripts + overlays. Contain organization-specific
# Docker Hub namespaces, Kubernetes context names, domain names, and
# watched-validator lists; kept local to repo maintainers rather than
# published. Fork users should write their own equivalents pointing at
# their own infra.
build.sh
deploy.sh
deploy/helm/**/values-*.yaml
!deploy/helm/**/values.yaml
tmp/
*.tsbuildinfo
.helmignore.local
deploy/helm/**/charts/
deploy/helm/**/Chart.lock

# Local operator-only files. Keep private dashboards, ad-hoc scripts,
# exported Grafana JSON, and cluster-specific notes out of commits.
ops-local/

# Playwright / Claude preview artifacts — screenshots and DOM snapshots
# dropped by playwright during UI preview runs. Useful at debug time,
# not worth committing.
.playwright-mcp/
/*.png
