{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "build",
  "framework": null,
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://whoearns.live/v1/:path*"
    },
    {
      "source": "/healthz",
      "destination": "https://whoearns.live/healthz"
    },
    {
      "source": "/openapi.yaml",
      "destination": "https://whoearns.live/openapi.yaml"
    },
    {
      "source": "/og/:path*",
      "destination": "https://whoearns.live/og/:path*"
    },
    {
      "source": "/mcp",
      "destination": "https://whoearns.live/mcp"
    },
    {
      "source": "/income/:path*",
      "destination": "/spa-fallback.html"
    },
    {
      "source": "/compare",
      "destination": "/spa-fallback.html"
    },
    {
      "source": "/claim/:path*",
      "destination": "/spa-fallback.html"
    }
  ]
}
