# Empty PUBLIC_* placeholders — required for SvelteKit's `$env/static/public`
# type generation to resolve imports in `$lib/site.ts` and `$lib/api.ts`.
#
# Real values come from one of:
#   - Docker build: `--build-arg PUBLIC_SITE_URL=...` → ENV → svelte-kit sync
#   - Local dev:    `ui/.env.local` (gitignored — never put secrets in committed `.env`)
#
# When PUBLIC_SITE_URL is empty, `$lib/site.ts` falls back to
# `http://localhost:8080`. That fallback is intentionally broken-looking
# so a forgotten production override surfaces in crawler logs immediately
# instead of silently leaking the upstream operator's domain.
PUBLIC_SITE_URL=
PUBLIC_INDEXER_API_URL=
# Solana JSON-RPC endpoint the operator-wallet memo-tx registration
# calls from the browser (recent blockhash, wallet balance, tx
# confirmation). Empty → falls back to the keyless public RPC
# https://solana-rpc.publicnode.com. Operators expecting heavier use
# can override this with a dedicated RPC at build time.
PUBLIC_SOLANA_RPC_URL=
