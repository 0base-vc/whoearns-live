# Runtime mode (used by src/index.ts dispatcher; entrypoints directly also work)
NODE_ENV=development
LOG_LEVEL=info

# HTTP API
HTTP_PORT=8080
HTTP_HOST=0.0.0.0
METRICS_PORT=0
SITE_URL=http://localhost:8080
SITE_NAME=WhoEarns
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MS=60000

# Solana RPC (mainnet only for MVP). Public RPC default; expect rate limits when tracking many validators.
SOLANA_RPC_URL=https://solana-rpc.publicnode.com
SOLANA_RPC_TIMEOUT_MS=30000
SOLANA_RPC_CONCURRENCY=4
SOLANA_RPC_MAX_RETRIES=3
SOLANA_RPC_CREDITS_PER_SEC=0
SOLANA_RPC_BURST_CREDITS=0

# Optional secondary RPCs. SOLANA_FALLBACK_RPC_URL is the live-worker
# block-fetch fallback (only used after the primary endpoint fails).
# SOLANA_ARCHIVE_RPC_URL serves two consumers:
#   1. The wallet-fee backfill's incremental polling (routine ticks
#      once a wallet has been backfilled once — ~60h history suffices).
#   2. The offline refill-income script's best-effort hot path.
# When unset, the backfill falls back to the primary RPC for both
# tiers (functional, just more expensive). publicnode is a free pick.
# SOLANA_FALLBACK_RPC_URL=
# SOLANA_ARCHIVE_RPC_URL=https://solana-rpc.publicnode.com

# Optional live block stream. JSON-RPC remains the repair/backfill source of truth.
# YELLOWSTONE_GRPC_URL=
# YELLOWSTONE_GRPC_X_TOKEN=

# PostgreSQL connection string
POSTGRES_URL=postgres://indexer:indexer@localhost:5432/indexer
POSTGRES_POOL_SIZE=10
POSTGRES_STATEMENT_TIMEOUT_MS=10000

# Validator watch list
#   - Comma-separated vote pubkeys, e.g. "Vote111...,Vote222..."
#   - Or "*" to track all active validators (WARNING: heavy RPC load — use a paid RPC provider).
VALIDATORS_WATCH_LIST=

# Job intervals (milliseconds)
EPOCH_WATCH_INTERVAL_MS=30000
SLOT_INGEST_INTERVAL_MS=60000
FEE_INGEST_INTERVAL_MS=30000
FEE_INGEST_BATCH_SIZE=50
AGGREGATES_INTERVAL_MS=300000
CLOSED_EPOCH_RECONCILE_INTERVAL_MS=300000
VALIDATOR_INFO_INTERVAL_MS=21600000
# Cluster-nodes (gossip ContactInfo) refresh — drives Phase 2 client
# classification (Agave / Jito-Solana / Firedancer / ...). 30 minutes
# balances badge freshness against ~500 KB per refresh.
CLUSTER_NODES_INTERVAL_MS=1800000
# Phase 4 — wallet daily-activity ingester cadence. Each tick
# enumerates registered operator wallets and runs
# `getSignaturesForAddress` once per wallet to derive per-day
# tx counts. 6 hours is enough resolution for the daily heatmap.
WALLET_ACTIVITY_INTERVAL_MS=21600000
# Phase 4-extension — wallet fee backfill cadence + per-tick budget.
# Tiered RPC routing: initial 365-day backfill per wallet hits
# SOLANA_RPC_URL (full history); routine incremental polling hits
# SOLANA_ARCHIVE_RPC_URL (~60h window suffices). 1 h cadence + 500
# fetches/wallet/tick is the calibrated baseline.
WALLET_FEE_BACKFILL_INTERVAL_MS=3600000
WALLET_FEE_BACKFILL_PER_TICK_LIMIT=500
# Phase 2-extension — validators.app canonical client-kind ingester.
# Fixed 6 h cadence: one bulk HTTP fetch + idempotent upsert per
# tick. Operators upgrade on hour-scale cycles at fastest and the
# upstream snapshots gossip on a similar timescale, so polling
# faster gives no extra signal.
VALIDATORS_APP_INTERVAL_MS=21600000
# Phase 5 — SIMD curation pipeline cadence. Each tick enriches
# pending SIMD proposals via the Anthropic API. 12 hours is plenty
# — SIMDs land on a governance timescale, not a slot timescale.
SIMD_CURATION_INTERVAL_MS=43200000

# Phase 5 — Anthropic Claude API, used only by the SIMD curation
# pipeline. Leave ANTHROPIC_API_KEY unset to disable curation
# entirely: the SIMD route still serves already-curated rows, but
# new SIMDs stay pre-review until populated.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Reorg safety buffer (slots). Blocks within this distance from tip are not yet processed.
SLOT_FINALITY_BUFFER=32

# Graceful shutdown
SHUTDOWN_TIMEOUT_MS=15000
