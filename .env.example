# Runtime mode (used by src/index.ts dispatcher; entrypoints directly also work)
NODE_ENV=development
LOG_LEVEL=info

# HTTP API
HTTP_PORT=8080
HTTP_HOST=0.0.0.0
METRICS_PORT=0
SITE_URL=http://localhost:8080
SITE_NAME=WhoEarns
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MS=60000

# Solana RPC (mainnet only for MVP). Public RPC default; expect rate limits when tracking many validators.
SOLANA_RPC_URL=https://solana-rpc.publicnode.com
SOLANA_RPC_TIMEOUT_MS=30000
SOLANA_RPC_CONCURRENCY=4
SOLANA_RPC_MAX_RETRIES=3
SOLANA_RPC_CREDITS_PER_SEC=0
SOLANA_RPC_BURST_CREDITS=0

# Optional secondary RPCs. The live worker uses SOLANA_FALLBACK_RPC_URL only after
# the primary endpoint fails; SOLANA_ARCHIVE_RPC_URL is kept for one-shot scripts.
# SOLANA_FALLBACK_RPC_URL=
# SOLANA_ARCHIVE_RPC_URL=

# Optional live block stream. JSON-RPC remains the repair/backfill source of truth.
# YELLOWSTONE_GRPC_URL=
# YELLOWSTONE_GRPC_X_TOKEN=

# PostgreSQL connection string
POSTGRES_URL=postgres://indexer:indexer@localhost:5432/indexer
POSTGRES_POOL_SIZE=10
POSTGRES_STATEMENT_TIMEOUT_MS=10000

# Validator watch list
#   - Comma-separated vote pubkeys, e.g. "Vote111...,Vote222..."
#   - Or "*" to track all active validators (WARNING: heavy RPC load — use a paid RPC provider).
VALIDATORS_WATCH_LIST=

# Job intervals (milliseconds)
EPOCH_WATCH_INTERVAL_MS=30000
SLOT_INGEST_INTERVAL_MS=60000
FEE_INGEST_INTERVAL_MS=30000
FEE_INGEST_BATCH_SIZE=50
AGGREGATES_INTERVAL_MS=300000
CLOSED_EPOCH_RECONCILE_INTERVAL_MS=300000
VALIDATOR_INFO_INTERVAL_MS=21600000

# Reorg safety buffer (slots). Blocks within this distance from tip are not yet processed.
SLOT_FINALITY_BUFFER=32

# Graceful shutdown
SHUTDOWN_TIMEOUT_MS=15000
